@using _67_Blankets_Mandela_Day_Application3.Models
@model LoginViewModel
@{
    ViewBag.Title = "Log in";
}

<div class="container-fluid vh-100 d-flex justify-content-end align-items-center">
    <!-- Flex container for vertical centering -->
    <div class="col-md-6">
        <!-- Increased column width -->
        <!-- Adjust the column width to make the card bigger -->
        <div class="card shadow">
            <div class="card-body">
                <h1 class="text-center text-danger">67 Blankets</h1>
                <h3 class="text-center">Login</h3>
                <p class="text-center mb-4">Use your account to log in</p>

                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group">
                        @Html.LabelFor(m => m.Email, new { @class = "control-label font-weight-bold" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", placeholder = "Email Address" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>




                    <div class="form-group">
                        @Html.LabelFor(m => m.Password, new { @class = "control-label font-weight-bold" })
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg", placeholder = "Password" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                            @Html.LabelFor(m => m.RememberMe, "Remember me", new { @class = "form-check-label" })
                        </div>
                        <a href="#" class="text-muted">Forgot password?</a>
                    </div>


                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-danger btn-lg btn-block">Log In</button>
                    </div>

                    <div class="text-center mt-3">
                        <p class="mb-0">New user? @Html.ActionLink("Register here", "Register", null, new { @class = "text-dark font-weight-bold" })</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Full viewport height for centering */
        .vh-100 {
            height: 100vh; /* Full viewport height */
        }

        /* Background image for the login page */
        body {
            background-image: url('/images/background.jpg'); /* Path to your background image */
            background-size: cover; /* Cover the entire viewport */
            background-position: center; /* Center the image */
            background-repeat: no-repeat; /* Prevent the image from repeating */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; /* Consistent font */
            margin: 0; /* Remove default body margin */
            color: #fff; /* Optional: Set text color to white for better contrast */
        }

        .card {
            border-radius: 10px; /* Rounded corners */
            background-color: rgba(255, 255, 255, 0.9); /* Slightly transparent white for card background */
            border: 1px solid #c0392b; /* Card border color */
            padding: 60px; /* Increased padding for more space inside the card */
            /* Optionally set a min-height to ensure card is always large enough */
            min-height: 400px; /* Minimum height for the card */
        }

        h1 {
            font-size: 2.5rem; /* Title size */
            margin-bottom: 20px; /* Space below title */
            color: #c0392b; /* Dark red color */
        }

        h3 {
            margin-bottom: 10px; /* Space below sub-title */
        }

        .form-control {
            border-radius: 5px; /* Rounded input fields */
            padding: 10px 15px; /* Padding for input */
            font-size: 1rem; /* Font size for input */
            margin-bottom: 15px; /* Space between input fields */
            border: 1px solid #c0392b; /* Dark red border color */
        }

            .form-control:focus {
                border-color: #a93226; /* Darker red focus border color */
                box-shadow: 0 0 5px rgba(192, 57, 43, 0.5); /* Focus shadow effect */
            }

        .form-group {
            margin-bottom: 1.5rem; /* Space between form groups */
        }

        .text-danger {
            font-size: 0.875rem; /* Smaller error messages */
        }

        .btn-danger {
            background-color: #c0392b; /* Button color */
            border-color: #c0392b; /* Button border color */
            transition: background-color 0.3s; /* Smooth transition */
        }

            .btn-danger:hover {
                background-color: #a93226; /* Darker red shade on hover */
                border-color: #922b21; /* Darker border on hover */
            }

        /* Card shadow for elevation effect */
        .shadow {
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }
    </style>
}

@{
    ViewBag.Title = "Admin";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"> <!-- Font Awesome for icons -->
    <style>

        .approve-btn {
            background-color: #28a745; /* Green */
            color: white;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 5px;
            transition: background 0.3s;
        }

        .reject-btn {
            background-color: #dc3545; /* Red */
            color: white;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 5px;
            transition: background 0.3s;
        }

        .approve-btn:hover {
            background-color: #c82333; /* Darker Green */
        }

        .reject-btn:hover {
            background-color: #c82333; /* Darker Red */
        }


        /* Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: #f4f6f9;
            color: #333;
        }

        /* Sidebar Styling */


        /* Main Dashboard */
        .main-content {
            margin-left: 250px;
            padding: 20px;
            width: calc(100% - 250px);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 20px;
            border-bottom: 2px solid #ddd;
        }

            .header h1 {
                font-size: 2em;
                color: #dc3545;
            }

        /* Dashboard Cards */
        .dashboard-cards {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }

        .card {
            background-color: #dc3545;
            color: white;
            padding: 20px;
            border-radius: 10px;
            flex: 1;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

            .card h3 {
                font-size: 1.5em;
                margin-bottom: 10px;
            }

            .card p {
                font-size: 2em;
            }

        /* Table Styling */
        .admin-table {
            margin-top: 20px;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
        }

            .admin-table table {
                width: 100%;
                border-collapse: collapse;
            }

            .admin-table th, .admin-table td {
                padding: 15px;
                text-align: left;
                border-bottom: 1px solid #ddd;
            }

            .admin-table th {
                background-color: #dc3545;
                color: white;
                font-weight: bold;
            }

            .admin-table tr:hover {
                background-color: #f1f1f1;
            }

        .table-controls button {
            margin-left: 10px;
            padding: 8px 15px;
            background-color: #c82333;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background 0.3s;
        }

            .table-controls button:hover {
                background-color: #c82333;
            }


        .sidebar {
            position: fixed; /* Make sidebar fixed */
            top: 60px; /* Sit below the navbar */
            left: 0; /* Align to the left */
            height: calc(100vh - 60px); /* Full height minus navbar */
            width: 250px;
            background-color: black; /* Match hero background color */
            padding-top: 20px;
            z-index: 1000;
            box-shadow: 2px 0 5px rgba(0, 0, 0, 0.2);
            border-radius: 0 10px 10px 0; /* Rounded right corners */
            transition: left 0.3s; /* Smooth transition for sidebar */
        }

            .sidebar a {
                color: white;
                padding: 15px 20px;
                text-decoration: none;
                display: block;
                font-weight: bold;
                transition: background-color 0.3s;
                border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            }

                .sidebar a:hover {
                    background-color: rgba(255, 255, 255, 0.2);
                    color: #000000;
                }

        .menu-button {
            position: fixed;
            top: 10px; /* Position at the top */
            left: 10px; /* Align to the left */
            background-color: black; /* Same color as sidebar */
            color: white;
            border: none;
            border-radius: 5px;
            padding: 10px;
            cursor: pointer;
            z-index: 1100; /* Above sidebar */
            transition: background-color 0.3s;
            color: white;
        }

            .menu-button:hover {
                background-color: white;
                color: #fff;
            }
    </style>
    
    <script>
        // JavaScript for Sidebar
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            sidebar.style.left = sidebar.style.left === "0px" ? "-250px" : "0px";
        }

        // JavaScript for Edit and Delete
        function editItem(id) {
            alert("Edit functionality for item ID " + id);
            // Implement AJAX request or redirect to edit page here.
        }

        function deleteItem(id) {
            if (confirm("Are you sure you want to delete this item?")) {
                alert("Delete functionality for item ID " + id);
                // Implement AJAX request or delete functionality here.
            }
        }
    </script>
</head>
<body>

    <button class="menu-button" onclick="toggleSidebar()">☰ Menu</button>



@{
    ViewBag.Title = "Thank_you_Check";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank You</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(to right, #fff, #fff); /* Gradient background */
            color: #333;
            text-align: center;
            padding: 20px;
            overflow: hidden; /* Prevent overflow for a cleaner look */
        }

        h1 {
            color: #4B0082; /* Deep purple for a vibrant look */
            margin-bottom: 20px;
            font-size: 2.5em; /* Increase font size for emphasis */
        }

        p {
            font-size: 18px;
            margin: 0;
            padding: 10px;
            background-color: rgba(255, 255, 255, 0.8); /* Semi-transparent background */
            border-radius: 5px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2); /* Soft shadow for depth */
        }

        .image-container {
            margin: 20px 0;
        }

        img {
            width: 300px; /* Responsive image width */
            height: auto;
            border-radius: 10px; /* Rounded corners for a soft look */
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        .footer {
            position: absolute;
            bottom: 20px;
            width: 100%;
            text-align: center;
            font-size: 14px;
            color: #fff;
            background-color: rgba(0, 0, 0, 0.6);
            padding: 10px 0;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <div>
        <h1>Thank You for Supporting 67 Blankets Mandela Day Initiative!</h1>
        <div class="image-container">
            <img src="~/Images/official_logo.png" alt="67 Blankets Mandela Day Initiative">
        </div>
        <p>Your kindness will help keep many warm this winter. Have a wonderful day!</p>
    </div>
   
</body>
</html>


